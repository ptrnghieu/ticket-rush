# ──────────────────────────────────────────
# Application
# ──────────────────────────────────────────
APP_NAME=TicketRush
DEBUG=false
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ──────────────────────────────────────────
# Database — Master (all writes)
# ──────────────────────────────────────────
DB_MASTER_HOST=localhost
DB_MASTER_PORT=3306
DB_MASTER_USER=root
DB_MASTER_PASSWORD=password
DB_NAME=ticketrush

# ──────────────────────────────────────────
# Database — Slaves (reads, comma-separated host:port)
# Leave blank to fall back to master (single-node dev)
# Example: DB_SLAVE_HOSTS=slave1:3306,slave2:3306
# ──────────────────────────────────────────
DB_SLAVE_HOSTS=
DB_SLAVE_USER=
DB_SLAVE_PASSWORD=

# ──────────────────────────────────────────
# Redis
# ──────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ──────────────────────────────────────────
# Business Rules
# ──────────────────────────────────────────
QUEUE_BATCH_SIZE=50
SEAT_LOCK_DURATION_SECONDS=600
