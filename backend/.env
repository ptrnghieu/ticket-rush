# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ticketrush
DB_USER=postgres
DB_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=24h

# Seat Lock
SEAT_LOCK_TTL_SECONDS=600

# Virtual Queue
MAX_CONCURRENT_USERS=200
QUEUE_BATCH_SIZE=50
QUEUE_RELEASE_INTERVAL_MS=30000
